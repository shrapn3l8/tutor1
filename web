                <p>&copy; 2024 Tutor Name. Все права защищены.</p>
                <div class="flex gap-4 mt-4 md:mt-0">
                    <a href="#" class="hover:text-white transition">Политика конфиденциальности</a>
                    <a href="#" class="hover:text-white transition">Договор оферты</a>
                </div>
            </div>
        </div>
    </section>

    <!-- JavaScript Logic -->
    <script>
        // --- Data Definitions ---

        const testimonialsData = [
            {
                id: 1,
                name: "Елена",
                role: "Мама ученика (8 лет)",
                text: "Мой сын ненавидел английский в школе. Спустя 2 месяца занятий он сам просит включить мультики на английском! Огромное спасибо за подход.",
                category: "kids",
                rating: 5
            },
            {
                id: 2,
                name: "Максим",
                role: "IT-специалист",
                text: "Нужен был технический английский для работы. Подтянули грамматику и сняли языковой барьер. Теперь спокойно прохожу собеседования.",
                category: "adults",
                rating: 5
            },
            {
                id: 3,
                name: "Анна",
                role: "Студентка",
                text: "Готовилась к ЕГЭ. Очень боялась устной части. Разобрали все ловушки экзамена, сдала на 92 балла! Это победа.",
                category: "exams",
                rating: 5
            },
            {
                id: 4,
                name: "Дмитрий",
                role: "Путешественник",
                text: "Испанский казался сложным, но методика просто огонь. Через полгода уже мог объясняться в Барселоне.",
                category: "adults",
                rating: 5
            },
            {
                id: 5,
                name: "Светлана",
                role: "Мама ученицы (14 лет)",
                text: "Дочь стала лучше учиться в школе, оценки исправились с троек на пятерки. Очень благодарны.",
                category: "kids",
                rating: 5
            },
            {
                id: 6,
                name: "Игорь",
                role: "Предприниматель",
                text: "Коротко, ясно, по делу. Ценим мое время. Прогресс виден уже через месяц.",
                category: "adults",
                rating: 4
            }
        ];

        // --- Core Functions ---

        document.addEventListener('DOMContentLoaded', () => {
            initCharts();
            renderTestimonials('all');
            setupNavigation();
        });

        // 1. Navigation Logic
        function setupNavigation() {
            // Mobile menu toggle
            const btn = document.getElementById('mobile-menu-btn');
            const menu = document.getElementById('mobile-menu');
            
            btn.addEventListener('click', () => {
                menu.classList.toggle('hidden');
            });
        }

        function scrollToSection(id) {
            const element = document.getElementById(id);
            if (element) {
                element.scrollIntoView({ behavior: 'smooth' });
                document.getElementById('mobile-menu').classList.add('hidden');
            }
        }

        // 2. Chart.js Implementations (Colors Updated)
        function initCharts() {
            // Chart 1: Demographics (Doughnut)
            const ctx1 = document.getElementById('demographicsChart').getContext('2d');
            new Chart(ctx1, {
                type: 'doughnut',
                data: {
                    labels: ['Дети (7-14)', 'Подростки (14-18)', 'Взрослые (18+)'],
                    datasets: [{
                        data: [40, 35, 25],
                        backgroundColor: [
                            '#560319', // Burgundy
                            '#3c1716', // Willow
                            '#b0a8a6'  // Muted grey/brown
                        ],
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                font: { family: 'Montserrat', size: 12 },
                                color: '#3c1716', // Willow
                                padding: 20
                            }
                        },
                        tooltip: {
                            backgroundColor: '#F2EFE7',
                            titleColor: '#2A1F1A',
                            bodyColor: '#3c1716',
                            borderColor: '#3c1716',
                            borderWidth: 1,
                            padding: 12,
                        }
                    },
                    cutout: '70%'
                }
            });

            // Chart 2: Experience/Timeline
            const ctx2 = document.getElementById('experienceChart').getContext('2d');
            new Chart(ctx2, {
                type: 'bar',
                data: {
                    labels: ['2018', '2019', '2020', '2021', '2022', '2023', '2024'],
                    datasets: [
                        {
                            label: 'Интенсивность обучения (Теория)',
                            data: [80, 90, 100, 95, 80, 60, 40],
                            type: 'line',
                            borderColor: '#3c1716', // Willow
                            borderWidth: 2,
                            borderDash: [5, 5],
                            tension: 0.4,
                            pointRadius: 0
                        },
                        {
                            label: 'Практика преподавания (Часы)',
                            data: [0, 10, 20, 40, 70, 90, 100],
                            backgroundColor: '#560319', // Burgundy
                            borderRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            display: false
                        },
                        x: {
                            grid: { display: false },
                            ticks: {
                                font: { family: 'Montserrat' },
                                color: '#3c1716'
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                padding: 20,
                                font: { family: 'Montserrat', size: 11 },
                                color: '#2A1F1A'
                            }
                        },
                        tooltip: {
                            backgroundColor: '#F2EFE7',
                            titleColor: '#2A1F1A',
                            bodyColor: '#3c1716',
                            borderColor: '#3c1716',
                            borderWidth: 1,
                        }
                    }
                }
            });
        }

        // 3. Testimonial Filtering
        function renderTestimonials(filter) {
            const grid = document.getElementById('testimonials-grid');
            grid.innerHTML = ''; 

            const filtered = filter === 'all' 
                ? testimonialsData 
                : testimonialsData.filter(t => t.category === filter);

            grid.classList.add('opacity-0', 'transition', 'duration-300');
            
            setTimeout(() => {
                filtered.forEach(t => {
                    const stars = Array(t.rating).fill('<i class="fas fa-star text-[#560319] text-xs"></i>').join('');
                    
                    const card = document.createElement('div');
                    card.className = "bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition border border-willow/10 flex flex-col";
                    card.innerHTML = `
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 rounded-full bg-bone flex items-center justify-center text-willow font-bold">
                                ${t.name[0]}
                            </div>
                            <div>
                                <h4 class="font-bold text-steeped text-sm">${t.name}</h4>
                                <p class="text-xs text-willow">${t.role}</p>
                            </div>
                            <div class="ml-auto">${stars}</div>
                        </div>
                        <p class="text-steeped/80 text-sm italic leading-relaxed mb-4 flex-1">"${t.text}"</p>
                        <div class="text-xs font-semibold text-burgundy uppercase tracking-wider">${getCategoryName(t.category)}</div>
                    `;
                    grid.appendChild(card);
                });
                grid.classList.remove('opacity-0');
            }, 150);
        }

        function getCategoryName(cat) {
            const map = { 'kids': 'Дети', 'adults': 'Взрослые', 'exams': 'Экзамены' };
            return map[cat] || cat;
        }

        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                document.querySelectorAll('.filter-btn').forEach(b => {
                    b.classList.remove('bg-burgundy', 'text-white');
                    b.classList.add('bg-white', 'text-willow');
                });
                e.target.classList.remove('bg-white', 'text-willow');
                e.target.classList.add('bg-burgundy', 'text-white');
                
                renderTestimonials(e.target.dataset.filter);
            });
        });

    </script>
</body>
</html>
